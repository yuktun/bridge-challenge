      },
      "hiddenBonus": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "intelDareBonus": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "scores": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "state": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "superBonus": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "superBonusAnnouncement": {
        ".read": "auth != null",
